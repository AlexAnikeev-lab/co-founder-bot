# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID администратора (можно узнать у @userinfobot)
ADMIN_ID=your_admin_id_here

# URL базы данных (по умолчанию SQLite)
DATABASE_URL=sqlite+aiosqlite:///cofounder.db

# Минимальный возраст для полного функционала
MIN_AGE_FULL=14

# OpenRouter API ключ (опционально, для ИИ функций)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_SITE_NAME=Co-founder Bot

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Подписка (оплата по коду в группу)
SUBSCRIPTION_STARS_PRICE=55
# ID группы оплаты (бот должен быть в группе). Для супергруппы — отрицательное, например -1001234567890. Как узнать: отправь в группу любое сообщение и посмотри getUpdates или добавь @userinfobot и перешли туда сообщение из группы
PAYMENT_GROUP_ID=
# Ссылка на группу оплаты (t.me/... или invite)
PAYMENT_GROUP_LINK=
# Префикс кода (итоговый код = PAYMENT_CODE_BASE_<telegram_id>)
PAYMENT_CODE_BASE=S4K3FF
# Ссылка на бота для покупки звёзд (под слово «ссылка» в экране подписки)
BUY_STARS_BOT_URL=https://t.me/your_stars_bot
