BOT_TOKEN=your_bot_token_here
ADMIN_ID=123456789
# Несколько админов — через запятую: ADMIN_ID=123,456,789

# Тестовый режим: true — подгружается .env.test поверх .env (токен, БД, группа оплаты и т.д.)
TEST_MODE=false

# Тестовый бот: лучше отдельная БД, иначе в анкетах останутся file_id от прод-бота
# (бот отправит текст без фото — это нормально). Для картинок регистрации на новом боте:
#   python scripts/upload_photos_for_file_id.py
#   python scripts/upload_photos_for_file_id_en.py
#   python scripts/upload_event_photo_file_id.py

# База данных
DATABASE_URL=sqlite+aiosqlite:///cofounder.db
# Тест: DATABASE_URL=sqlite+aiosqlite:///cofounder_test.db

# Полный функционал доступен с этого возраста
MIN_AGE_FULL=14

# Логирование
LOG_LEVEL=INFO

# Подписка (оплата по коду в группу)
SUBSCRIPTION_STARS_PRICE=100
PAYMENT_GROUP_ID=
PAYMENT_GROUP_LINK=
PAYMENT_CODE_BASE=S4K3FF
BUY_STARS_BOT_URL=https://t.me/...

# OpenRouter (опционально)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=Co-founder Bot

